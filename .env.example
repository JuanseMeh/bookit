# BookIt Environment Variables Example
# Copy to .env and adjust as needed.
# Backend reads DATABASE_URL from .env (overrides docker-compose if present).
# Frontend reads NEXT_PUBLIC_API_URL at build time.

# Database (matches docker-compose.yml defaults)
POSTGRES_DB=bookit
POSTGRES_USER=bookit
POSTGRES_PASSWORD=bookit

# Backend DATABASE_URL template (use in local dev, docker-compose overrides)
# DATABASE_URL=postgres://bookit:bookit@localhost:5432/bookit

# Frontend API URL (docker-compose sets to http://backend:3001)
# NEXT_PUBLIC_API_URL=http://localhost:3001
